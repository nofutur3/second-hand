# API Configuration
# NUXT_API_BASE_SERVER: used for server-side (SSR) requests, which run
# inside the Docker network and need the internal "api" hostname.
# NUXT_PUBLIC_API_BASE: used for requests made from the browser (client-
# side navigation, the create/delete forms) - needs a URL your browser
# can actually reach, e.g. localhost if you're running this locally.
NUXT_API_BASE_SERVER=http://api:8091/api/v1
NUXT_PUBLIC_API_BASE=http://localhost:8091/api/v1

# Server Configuration
NUXT_HOST=0.0.0.0
NUXT_PORT=8092
