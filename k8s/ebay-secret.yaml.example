# Applied once by hand (kubectl apply -f), not part of the CI/CD pipeline:
#   cp k8s/ebay-secret.yaml.example k8s/ebay-secret.yaml
#   # edit the values below to the real eBay Developer + Telegram bot credentials
#   kubectl apply -f k8s/ebay-secret.yaml
#   rm k8s/ebay-secret.yaml   # don't leave the real secret on disk longer than needed
apiVersion: v1
kind: Secret
metadata:
  name: secondhand-ebay
  namespace: secondhand
type: Opaque
stringData:
  EBAY_CLIENT_ID: CHANGE_ME
  EBAY_CLIENT_SECRET: CHANGE_ME
  TELEGRAM_BOT_TOKEN: CHANGE_ME
  TELEGRAM_CHAT_ID: CHANGE_ME
