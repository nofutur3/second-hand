# Applied once by hand (kubectl apply -f), not part of the CI/CD pipeline:
#   cp k8s/postgres-secret.yaml.example k8s/postgres-secret.yaml
#   # edit the password below to something real, e.g. `openssl rand -base64 24`
#   kubectl apply -f k8s/postgres-secret.yaml
#   rm k8s/postgres-secret.yaml   # don't leave the real secret on disk longer than needed
apiVersion: v1
kind: Secret
metadata:
  name: secondhand-postgres
  namespace: secondhand
type: Opaque
stringData:
  password: CHANGE_ME
